# Управляется Ansible (roles/backup). Источник для deployment/prod/backup.sh.
S3_BUCKET={{ backup_s3_bucket }}
S3_ENDPOINT={{ backup_s3_endpoint }}
AWS_ACCESS_KEY_ID={{ vault_backup_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ vault_backup_aws_secret_access_key }}
RETENTION_DAYS={{ backup_retention_days | default(7) }}
BACKUP_DIR={{ backup_dir | default('/var/backups/polymaths') }}
DB_NAME={{ db_name | default('yugabyte') }}
DB_USER={{ db_user | default('yugabyte') }}
YB_CONTAINER={{ yb_container | default('wibe_yugabytedb') }}
