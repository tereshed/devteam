# Управляется Ansible (roles/app). Корневой .env для интерполяции переменных в docker compose.
# НЕ путать с backend/.env (env_file контейнера app с ключами LLM/git).
DOMAIN={{ domain }}
ACME_EMAIL={{ acme_email }}
MCP_PUBLIC_URL={{ mcp_public_url | default('https://mcp.' + domain) }}
JWT_SECRET_KEY={{ vault_jwt_secret_key }}
ORCHESTRATOR_STEP_WORKERS={{ orchestrator_step_workers | default(3) }}
ORCHESTRATOR_AGENT_WORKERS={{ orchestrator_agent_workers | default(8) }}
DOCKER_GID={{ docker_gid }}
