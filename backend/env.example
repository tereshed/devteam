# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# Database Configuration (YugabyteDB)
DB_HOST=yugabytedb
DB_PORT=5433
DB_USER=yugabyte
DB_PASSWORD=yugabyte
DB_NAME=yugabyte
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# JWT Configuration
# ВАЖНО: Измените этот ключ в production!
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# Admin User Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword

# LLM Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

OPENROUTER_KEY=

# MCP (Model Context Protocol) Server Configuration
# MCP позволяет LLM-клиентам (Cursor, Claude Desktop, VS Code) подключаться к вашему сервису
MCP_ENABLED=false
MCP_PORT=8081
# ВАЖНО: В production укажите публичный URL (https://your-domain.com/mcp)
# Для локальной разработки можно не указывать — будет http://localhost:8081/mcp
MCP_PUBLIC_URL=
# Лимиты для MCP-инструментов (защита от перегрузки/стоимости)
MCP_MAX_PROMPT_RUNES=100000
MCP_MAX_TOKENS_LIMIT=32768
MCP_MAX_INPUT_RUNES=50000
